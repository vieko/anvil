{
  "name": "@anvil/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "anvil's first-class CLI: define an outcome, the agent works, a deterministic gate decides done.",
  "license": "MIT",
  "author": "vieko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vieko/anvil.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/vieko/anvil#readme",
  "bugs": {
    "url": "https://github.com/vieko/anvil/issues"
  },
  "bin": {
    "anvil": "./dist/bin.js"
  },
  "files": [
    "dist",
    "skills",
    "skill-data",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --conditions=source src/bin.ts",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anvil/core": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  }
