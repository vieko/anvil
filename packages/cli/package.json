{
  "name": "@vieko/anvil",
  "version": "0.1.3",
  "type": "module",
  "description": "anvil's first-class CLI: define an outcome, the agent works, a deterministic gate decides done.",
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "coding-agent",
    "autonomous-agent",
    "llm",
    "cli",
    "git-worktree",
    "code-generation",
    "verification",
    "tdd",
    "gate",
    "outcome-driven",
    "delegation"
  ],
  "license": "MIT",
  "author": "vieko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vieko/anvil.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/vieko/anvil#readme",
  "bugs": {
    "url": "https://github.com/vieko/anvil/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "anvil": "./dist/bin.js"
  },
  "files": [
    "dist",
    "skills",
    "skill-data",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npm run clean && esbuild src/bin.ts --bundle --platform=node --format=esm --target=node22 --conditions=source --external:@earendil-works/* --external:typebox --sourcemap --outfile=dist/bin.js",
    "dev": "node --conditions=source src/bin.ts",
    "test": "vitest --run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-ai": "0.78.1",
    "typebox": "1.1.38"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
