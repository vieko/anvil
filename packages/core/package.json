{
  "name": "@anvil/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The anvil engine: define outcome -> agent works -> deterministic gate -> loop.",
  "license": "MIT",
  "author": "vieko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vieko/anvil.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/vieko/anvil#readme",
  "bugs": {
    "url": "https://github.com/vieko/anvil/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "source": "./src/node/index.ts",
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-ai": "0.78.1",
    "typebox": "1.1.38"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
